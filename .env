# Mini TMK Agent - 环境变量配置示例
# 复制此文件为 .env 并填入你的实际配置

# ============================================
# ASR (语音识别) 配置
# ============================================

# ASR 服务提供商: openai 或 siliconflow
ASR_PROVIDER=siliconflow

# ASR API 密钥
# OpenAI: https://platform.openai.com/api-keys
# SiliconFlow: https://cloud.siliconflow.cn/
ASR_API_KEY="你的_asr_api_key_在这里"

# ASR API 端点
ASR_URL=https://api.siliconflow.cn/v1/audio/transcriptions

# ============================================
# 翻译服务配置
# ============================================

# 翻译服务提供商: openai, deepseek, 或 qwen
TRANSLATION_PROVIDER=deepseek

# 翻译 API 密钥
# OpenAI: https://platform.openai.com/api-keys
# DeepSeek: https://platform.deepseek.com/
# Qwen: https://dashscope.console.aliyun.com/
TRANSLATION_API_KEY="你的_translation_api_key_在这里"

# 翻译 API 端点
TRANSLATION_URL=https://api.deepseek.com/chat/completions

# ============================================
# 音频配置
# ============================================

# VAD (语音活动检测) 启用状态
VAD_ENABLED=true

# 音频采样率 (Hz)
# 推荐值: 16000 (标准)
# 其他: 8000 (低质量), 44100 (高质量)
SAMPLE_RATE=16000

# 音频位深度 (bits)
# 标准值: 16
BIT_DEPTH=16

# 音频通道数
# 标准值: 1 (单声道)
NUM_CHANNELS=1

# ============================================
# 调试配置
# ============================================

# 启用详细日志
# 使用 --verbose 命令行参数则不需要该设置
VERBOSE=false

# ============================================
# 代理配置 (可选，某些地区需要)
# ============================================

# HTTP 代理
# HTTP_PROXY=http://proxy.example.com:8080

# HTTPS 代理
# HTTPS_PROXY=https://proxy.example.com:8080

# ============================================
# 使用说明
# ============================================
# 
# 1. 复制此文件：cp .env.example .env
# 2. 编辑 .env 文件，填入你的 API 密钥
# 3. 确保 .env 在项目根目录
# 4. 运行程序时会自动加载 .env 文件
#
# 类型说明:
# - string: 字符串，需要用引号包裹特殊字符
# - boolean: true 或 false
# - number: 整数或浮点数
